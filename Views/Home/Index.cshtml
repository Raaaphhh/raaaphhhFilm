@{
    ViewData["Title"] = "Home Page";
    var videos = ViewBag.Videos as Dictionary<string, (string Url, bool IsPrivate, string CodeSecret)>; 
    var codeValid = (bool)ViewBag.CodeValid;
}

<br/>

<div class="container text-center mt-4">
    @foreach (var video in videos)
    {
        var title = video.Key;
        var url = video.Value.Url;
        var isPrivate = video.Value.IsPrivate;

        <div class="mb-5">
            <h2>@title</h2>
            @if (!isPrivate || codeValid)
            {
                <div class="ratio ratio-16x9">
                    <iframe src="@url"
                            title="YouTube video player"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            allowfullscreen></iframe>
                </div>
            }
            else
            {
                <p class="text-muted">Cette vidéo est protégée par un code secret.</p>
            }
        </div>
    }
    
    <form method="post" class="mb-5 p-4 rounded" style="background-color: #1e1e1e; max-width: 400px; margin: auto; font-family: 'Bitcount Prop Single', sans-serif;">
        <label for="Code" class="form-label text-light">Code secret global</label>
        <input type="tel" pattern="[0-9]*" inputmode="numeric" name="Code" class="form-control mb-3" placeholder="Entrez le code" 
               style="background-color: #2c2c2c; border: 1px solid #444; color: #fff;" required />
    
        <button type="submit" class="btn btn-outline-light w-100">🔓 Déverrouiller les vidéos</button>
    </form>
</div>